	"version": "0.2.0",
	"configurations": [
		{
			"name": "Actions from .env file",
			"type": "go",
			"request": "launch",
			"mode": "debug",
			"buildFlags": ["-tags=sqlite_math_functions"],
			"cwd": "${workspaceFolder}",
			"program": "${workspaceFolder}/cmd/territories-referee",
			"envFile": "${workspaceFolder}/.env",
			"env": {
				"ARGS_FROM_ENV": "1"
			}
		}
	]
}